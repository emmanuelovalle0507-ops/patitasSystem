# ============================================
# PatiTas - Variables de entorno
# ============================================

# --- Next ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (DB + Auth + Storage + Realtime) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Prisma (usa la cadena pooler de Supabase para runtime, direct para migraciones) ---
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."
# Modelo por defecto. Alternativas: gpt-4o (más caro, mejor), gpt-4o-mini (rápido y barato)
OPENAI_MODEL="gpt-4o-mini"

# --- Mapas ---
# No se requiere API key. Usamos MapLibre GL + OpenFreeMap (tiles gratuitos)
# y Nominatim para reverse geocoding. Si quieres cambiar a Mapbox, sustituye
# components/map/map-picker.tsx y define NEXT_PUBLIC_MAPBOX_TOKEN.

# --- Storage ---
# Usamos Supabase Storage. No se requieren variables adicionales; usa las
# llaves de Supabase de arriba. Crea un bucket público llamado "patitas-photos".

# --- Web Push (genera con: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contacto@patitas.mx"

# --- Resend (emails) ---
RESEND_API_KEY=""
RESEND_FROM="PatiTas <no-reply@patitas.mx>"
